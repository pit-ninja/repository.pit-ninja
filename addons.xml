<?xml version='1.0' encoding='utf-8'?>
<addons>
  <addon id="repository.pit-ninja" name="PitNinja" version="1.0.0" provider-name="PitNinja">
    <extension point="xbmc.addon.repository" name="PitNinja">
      <dir>
        <info compressed="false">https://pit-ninja.github.io/repository.pit-ninja/addons.xml</info>
        <checksum>https://pit-ninja.github.io/repository.pit-ninja/addons.xml.md5</checksum>
        <datadir zip="true">https://pit-ninja.github.io/repository.pit-ninja/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary>PitNinja</summary>
      <description>Hosting a custom AF3 fork for p3i with more to come.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="screensaver.atv4" name="Aerial" version="12.3.0.3" provider-name="pit-ninja">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.ui.screensaver" library="entrypointscreensaver.py" />
    <extension point="xbmc.python.script" library="entrypointscript.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" />
    <extension point="xbmc.addon.metadata">
      <platform>all</platform>
      <license>GPL-2.0-only</license>
      <source>https://github.com/enen92/screensaver.atv4</source>
      <forum>https://forum.kodi.tv/showthread.php?tid=246655</forum>
      <summary lang="en_GB">Apple TV Screensavers in Kodi</summary>
      <summary lang="es_ES">Protector de pantalla Apple TV para Kodi</summary>
      <description lang="en_GB">This screensaver addon provides Apple TV aerial screensavers in Kodi</description>
      <description lang="es_ES">Este complemento habilita el protector de pantalla Aerial de Apple TV para Kodi</description>
      <news>v12.3.0.3 (2026-07-14)
- Remove unused preview window code
- Add fade delay setting for transitions between videos (default: 1.0s)
- Refactor exit sequence to fix 2-button presses required to exit. (Necessary due to proposed changes in p3i.)
</news>
      <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
        <screenshot>resources/screenshots/screenshot-01.jpg</screenshot>
        <screenshot>resources/screenshots/screenshot-02.jpg</screenshot>
        <screenshot>resources/screenshots/screenshot-03.jpg</screenshot>
        <screenshot>resources/screenshots/screenshot-04.jpg</screenshot>
      </assets>
    </extension>
  </addon>
  <addon id="skin.arctic.fuse.3" name="Arctic Fuse 3 (p3i)" provider-name="jurialmunkey, jamal2362, swmarks" version="58.3.2.13">
    <requires>
      <import addon="xbmc.gui" version="5.17.0" />
      <import addon="script.skinvariables" version="2.2.2" />
      <import addon="script.texturemaker" version="0.2.9" />
      <import addon="plugin.video.themoviedb.helper" version="6.14.3" />
      <import addon="resource.images.weathericons.white" version="0.0.1" />
      <import addon="resource.images.studios.coloured" version="0.0.1" />
      <import addon="resource.font.robotocjksc" version="0.0.3" />
    </requires>
    <extension debugging="false" defaultthemename="Textures.xbt" effectslowdown="1" point="xbmc.gui.skin">
      <res aspect="16:9" default="true" folder="1080i" width="1920" height="1080" />
      <res aspect="3:2" default="false" folder="1080i" width="1620" height="1080" />
      <res aspect="4:3" default="false" folder="1080i" width="1440" height="1080" />
      <res aspect="16:10" default="false" folder="1080i" width="1728" height="1080" />
      <res aspect="17:9" default="false" folder="1080i" width="2040" height="1080" />
      <res aspect="21:9" default="false" folder="1080i" width="2520" height="1080" />
      <res aspect="19.5:9" default="false" folder="1080i" width="2340" height="1080" />
      <res aspect="18:9" default="false" folder="1080i" width="2160" height="1080" />
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en">A minimal row based skin</summary>
      <summary lang="es">Una skin minimalista de diseño horizontal</summary>
      <summary lang="de">Ein minimalistisches, zeilenbasiertes Skin</summary>
      <summary lang="zh">简约行式布局皮肤</summary>
      <summary lang="ar">سكن مخفف بقوائم افقية</summary>
      <description lang="en">Arctic Fuse 3 is a minimal row based skin with customisable widgets</description>
      <description lang="es">Arctic Fuse 3 es una skin minimalista de diseño horizontal con widgets personalizables</description>
      <description lang="de">Arctic Fuse 3 ist ein minimalistisches, zeilenbasiertes Skin mit anpassbaren Widgets</description>
      <description lang="zh">Arctic Fuse 3 是一款采用简约行式布局的 Kodi 皮肤，支持小组件自定义功能</description>
      <description lang="ar">Arctic Fuse 3 سكن مخفف بقوائم افقية وبامكانية تخصيص الاختصارات</description>
      <platform>all</platform>
      <license>Creative Commons Attribution Non-Commercial Share-Alike 4.0</license>
      <forum />
      <source />
      <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
      </assets>
    </extension>
  </addon>
</addons>